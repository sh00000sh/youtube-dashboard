# 이 값들을 Railway의 youtube-dashboard 서비스 → Variables 에 넣으세요.
# (.env 파일은 비밀이라 깃허브에 안 올라갑니다)

# --- 기존 ---
YOUTUBE_API_KEY=유튜브_API_키
CHANNEL_ID=UCkitMbZJ1j6P2RLf_tbklQQ

# --- OAuth (채널 분석용, 비밀 숫자 가져오기) ---
OAUTH_CLIENT_ID=구글_OAuth_클라이언트_ID
OAUTH_CLIENT_SECRET=구글_OAuth_클라이언트_시크릿
OAUTH_REFRESH_TOKEN=1//로_시작하는_리프레시_토큰

# --- 구글 시트 (로봇이 글 쓰기) ---
# 서비스계정 JSON 파일 "내용 전체"를 한 줄로 붙여넣기 ({ ... } 통째로)
GOOGLE_SERVICE_ACCOUNT={"type":"service_account", ... 전체 ... }
# 시트 ID = 시트 주소 /d/ 와 /edit 사이의 긴 문자열
SHEET_ID=1xI8_cYBf0CSF-6ndCAYZ_NcwrXGrtwE89yBW0G6o4Eg

# --- 선택(안 넣으면 기본값) ---
SYNC_DAYS=30          # 며칠치 가져올지
MAX_VIDEOS=50         # 영상 몇 개까지
DAILY_TAB=일별         # 일별 탭 이름
VIDEO_TAB=영상별       # 영상별 탭 이름
DAILY_FIRST_ROW=7     # 일별 데이터 시작 행
VIDEO_FIRST_ROW=3     # 영상별 데이터 시작 행
