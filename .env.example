# 이 파일을 복사해서 ".env" 라는 이름으로 만들고, 값을 채워 넣으세요.
# (.env 파일은 비밀이라 깃허브에 안 올라갑니다)

# 1) 유튜브 출입 열쇠 (구글 클라우드 콘솔에서 발급)
YOUTUBE_API_KEY=여기에_유튜브_API_키_붙여넣기

# 2) 채널 ID (UC로 시작하는 문자열) → 구독자/총조회수/총영상수 가져옴
#    찾는 법: 유튜브 스튜디오 → 설정 → 채널 → 고급 설정에 "채널 ID"가 있음
CHANNEL_ID=UCxxxxxxxxxxxxxxxxxxxxxx

# 3) 추적할 영상 ID들 (쉼표로 구분) → 영상별 조회/좋아요/댓글 가져옴
#    영상 ID = 유튜브 주소 watch?v= 뒤의 글자. 예) youtu.be/abc123XYZ -> abc123XYZ
VIDEO_IDS=영상ID1,영상ID2,영상ID3

# DATABASE_URL은 Railway가 자동으로 넣어줍니다. 내 컴퓨터 테스트 땐 비워두세요.
